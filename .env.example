# Static defaults for the local dev stack.
# scripts/dev-db-up.sh writes any computed PostgreSQL overrides to .clartk/dev/resolved.env.

POSTGRES_USER=clartk
POSTGRES_PASSWORD=clartk
CLARTK_POSTGRES_HOST=127.0.0.1
CLARTK_POSTGRES_PORT=5432
CLARTK_POSTGRES_VOLUME_NAME=clartk-postgres
CLARTK_DB_BACKUP_DIR=.clartk/dev/backups
CLARTK_POSTGRES_SUPERUSER_URL=postgresql://clartk:clartk@127.0.0.1:5432/postgres
CLARTK_RUNTIME_DATABASE_URL=postgresql://clartk:clartk@127.0.0.1:5432/clartk_runtime
CLARTK_DEV_DATABASE_URL=postgresql://clartk:clartk@127.0.0.1:5432/clartk_dev

PORT=3000
CLARTK_API_HOST=0.0.0.0
CLARTK_DASHBOARD_ORIGIN=http://localhost:5173
CLARTK_DEV_CONSOLE_ORIGIN=http://localhost:5180
CLARTK_SESSION_COOKIE_NAME=clartk_session
CLARTK_SESSION_TTL_HOURS=168
CLARTK_SESSION_COOKIE_SECURE=0
CLARTK_DASHBOARD_PORT=5173
CLARTK_DEV_CONSOLE_PORT=5180
CLARTK_DEV_CONSOLE_API_PORT=3300
VITE_CLARTK_API_BASE_URL=http://localhost:3000
VITE_CLARTK_DEV_CONSOLE_API_BASE_URL=http://localhost:3300

CLARTK_AGENT_MEMORY_HOST=0.0.0.0
CLARTK_AGENT_MEMORY_PORT=3100
CLARTK_AGENT_MEMORY_REVIEW_TOKEN=dev-review-token

CLARTK_GATEWAY_DIAGNOSTICS_HOST=0.0.0.0
CLARTK_GATEWAY_DIAGNOSTICS_PORT=3200
CLARTK_GATEWAY_MODE=hybrid
CLARTK_GATEWAY_FIXTURE_PATH=
CLARTK_GATEWAY_SERIAL_PORT=
CLARTK_GATEWAY_NTRIP_URL=

CLARTK_NATIVE_METRO_PORT=8081

CLARTK_BOOTSTRAP_ADMIN_EMAIL=admin@clartk.local
CLARTK_BOOTSTRAP_ADMIN_PASSWORD=clartk-admin
CLARTK_BOOTSTRAP_ADMIN_DISPLAY_NAME=ClaRTK Admin
