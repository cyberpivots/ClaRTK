{
  "name": "clartk",
  "private": true,
  "packageManager": "yarn@4.9.1",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/api",
    "services/dev-console-api"
  ],
  "scripts": {
    "contracts:generate": "node scripts/generate-contracts.mjs",
    "contracts:check": "node scripts/generate-contracts.mjs --check",
    "dev:db:up": "scripts/dev-db-up.sh",
    "dev:db:down": "scripts/dev-db-down.sh",
    "dev:db:init": "scripts/dev-db-init.sh",
    "dev:db:backup": "scripts/dev-db-backup.sh",
    "dev:db:restore": "scripts/dev-db-restore.sh",
    "dev:db:reset:soft": "scripts/dev-db-reset-soft.sh",
    "dev:db:reset:hard": "scripts/dev-db-reset-hard.sh",
    "dev:db:smoke": "scripts/dev-db-smoke.sh",
    "dev:auth:bootstrap": "scripts/dev-bootstrap-auth.sh",
    "dev:api": "scripts/dev-api.sh",
    "dev:dashboard": "scripts/dev-dashboard.sh",
    "dev:console": "scripts/dev-console.sh",
    "dev:console:api": "scripts/dev-console-api.sh",
    "dev:memory": "scripts/dev-agent-memory.sh",
    "dev:memory:worker": "scripts/dev-agent-memory-worker.sh",
    "dev:gateway": "scripts/dev-gateway.sh",
    "dev:status": "scripts/dev-status.sh",
    "lint": "tsc -b tsconfig.base.json --pretty false",
    "typecheck": "tsc -b tsconfig.base.json --pretty false",
    "test": "node scripts/run-js-tests.mjs",
    "build": "tsc -b tsconfig.base.json --pretty false"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
